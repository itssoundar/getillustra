{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install -g pnpm@10.26.1 && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/getillustra build",
  "outputDirectory": "artifacts/getillustra/dist/public",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
